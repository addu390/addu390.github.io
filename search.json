---
layout: null
---

[
  {% for post in site.posts %}
    {
      "title"    : "{{ post.title | strip_html | escape }}",
      "url"      : "{{ post.url }}",
      "date"     : "{{ post.date | date: '%b %-d, %Y' }}",
      "content"  : {{ post.content | strip_html | strip_newline | strip | jsonify }}
    },
  {% endfor %}

  {% for post in site.journals %}
    {
      "title"    : "{{ post.title | strip_html | escape }}",
      "url"      : "{{ post.url }}",
      "date"     : "{{ post.date | date: '%b %-d, %Y' }}",
      "content"  : {{ post.content | strip_html | strip_newline | strip | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
